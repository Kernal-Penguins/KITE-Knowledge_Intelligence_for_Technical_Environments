# =============================================================================
# KITE — Environment Variables
# Copy this file to `.env` in the project root (or `backend/.env` for local dev).
# Never commit real secrets.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=KITE
APP_ENV=development
APP_VERSION=0.1.0
# Comma-separated list of allowed browser origins (include prod URL when deploying)
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: gemini | openai | groq | ollama
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Neo4j (Knowledge Graph) ───────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kite_password

# ── PostgreSQL (Metadata & Audit Logs) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:kite_password@localhost:5432/kite

# ── Qdrant (Vector Store) ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Embeddings & Reranking ───────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Frontend (Vite — optional, baked in at build time) ───────────────────────
VITE_WORKSPACE_NAME=My Workspace
VITE_USER_INITIALS=KT

# ── Docker Compose overrides ──────────────────────────────────────────────────
# Used by docker-compose.yml — set your real API key before running the stack
# GEMINI_API_KEY=your_key_here
