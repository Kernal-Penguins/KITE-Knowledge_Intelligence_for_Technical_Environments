# ════════════════════════════════════════════════════════════
#  KITE — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────
LLM_PROVIDER=gemini                       # gemini | openai | groq | ollama
GEMINI_API_KEY=your-gemini-api-key-here   # https://aistudio.google.com/app/apikey
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Neo4j ────────────────────────────────────────────────────
# Dev (local Docker): bolt://localhost:7687
# Prod (Aura Free):   neo4j+s://xxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kite_password

# ── Qdrant ───────────────────────────────────────────────────
# Dev (local Docker): http://localhost:6333
# Prod (Qdrant Cloud): https://xxxx.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── PostgreSQL ───────────────────────────────────────────────
# Dev (local Docker)
DATABASE_URL=postgresql+asyncpg://kite:kite_password@localhost:5432/kite

# ── Application ──────────────────────────────────────────────
APP_ENV=development                       # development | production
APP_VERSION=0.1.0
APP_NAME=KITE
CORS_ORIGINS=http://localhost:5173

# ── Embedding & Reranking ────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large

# ── Vite (Frontend) ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
